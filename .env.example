# Password policy (frontend UX validation — mirrors the backend's rules).
# NOTE: VITE_* vars are PUBLIC — Vite inlines them into the client bundle at build
# time. Only put non-secret config here; never API keys / tokens / secrets.

# Minimum password length on registration (mirror PASSWORD_MIN_LENGTH on the API) - "8"
VITE_PASSWORD_MIN_LENGTH=8

# Password complexity (regex). Mirror PASSWORD_PATTERN on the API.
# Examples:
#   upper/lower/number/special: ^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[^A-Za-z0-9]).+$
#   upper/lower/number:         ^(?=.*[a-z])(?=.*[A-Z])(?=.*\d).+$
VITE_PASSWORD_PATTERN=^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[^A-Za-z0-9]).+$

# Message shown when the password fails the complexity regex.
VITE_PASSWORD_MESSAGE=Must include upper- and lowercase, a number and a special character.
